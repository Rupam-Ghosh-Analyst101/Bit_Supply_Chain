rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "u2wuF63HwxYLF6lIEpkI0PM1Tjt1" ||
        request.auth.token.email == "rupamghosh2k20@gmail.com"
      );
    }

    match /shipments/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);
      allow write: if isSignedIn() && (isAdmin() || request.resource.data.clientId == request.auth.uid);
    }
    
    match /inventory/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);
      allow write: if isSignedIn() && (isAdmin() || request.resource.data.clientId == request.auth.uid);
    }

    match /pricing/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /sourcing/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);
      allow write: if isSignedIn() && (isAdmin() || request.resource.data.clientId == request.auth.uid);
    }

    match /manufacturing/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);
      allow write: if isSignedIn() && (isAdmin() || request.resource.data.clientId == request.auth.uid);
    }

    match /market_stocks/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /client_orders/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /stock_news/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /client_requests/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);
      allow write: if isSignedIn() && (isAdmin() || request.resource.data.clientId == request.auth.uid);
    }

    match /client_documents/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);
      allow write: if isSignedIn() && (isAdmin() || request.resource.data.clientId == request.auth.uid);
    }

    match /vault_documents/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.clientId == request.auth.uid);
      allow write: if isSignedIn() && (isAdmin() || request.resource.data.clientId == request.auth.uid);
    }

    match /client_profiles/{userId} {
      allow read: if isSignedIn() && (isAdmin() || userId == request.auth.uid);
      allow write: if isSignedIn() && (isAdmin() || userId == request.auth.uid);
    }

    match /admins/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
